# Electron compatibility - use flat node_modules
node-linker=hoisted

# Auto-install peer dependencies
auto-install-peers=true

# Preserved from original npm config
node-options=--max-old-space-size=4096
update-notifier=false
engine-strict=true

# Supply-chain hardening: delay newly-published package versions by 24h.
# This reduces exposure to npm compromise windows like CVE-2026-45321 / GHSA-g7cv-rxg3-hmpx.
minimum-release-age=1440
