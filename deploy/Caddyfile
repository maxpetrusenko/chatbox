{
  auto_https off
  admin off
}

:8080 {
  route {
    @chatbox_api path /_chatbox_api /_chatbox_api/*
    handle @chatbox_api {
      uri strip_prefix /_chatbox_api
      reverse_proxy https://api.chatboxai.app {
        header_up Host api.chatboxai.app
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host api.chatboxai.app
        header_up X-Forwarded-Port 443
      }
    }

    @chatbox_origin path /_chatbox_origin /_chatbox_origin/*
    handle @chatbox_origin {
      uri strip_prefix /_chatbox_origin
      reverse_proxy https://chatboxai.app {
        header_up Host chatboxai.app
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host chatboxai.app
        header_up X-Forwarded-Port 443
      }
    }

    root * /usr/share/caddy
    encode gzip zstd

    @immutable {
      path /assets/*
      path *.js *.css *.woff *.woff2 *.ttf *.svg *.png *.jpg *.jpeg *.webp *.ico
    }
    header @immutable Cache-Control "public, max-age=31536000, immutable"

    try_files {path} {path}/ /index.html
    file_server
  }
}
