{
  auto_https off
  admin off
}

:8080 {
  root * /usr/share/caddy
  encode gzip zstd
  file_server

  @immutable {
    path /assets/*
    path *.js *.css *.woff *.woff2 *.ttf *.svg *.png *.jpg *.jpeg *.webp *.ico
  }
  header @immutable Cache-Control "public, max-age=31536000, immutable"

  try_files {path} {path}/ /index.html
}

